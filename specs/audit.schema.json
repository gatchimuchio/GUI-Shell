{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gui-shell/schemas/audit.schema.json",
  "title": "AuditEvent",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "action",
    "target",
    "result",
    "payload_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "enum": [
        "user",
        "shell",
        "runtime",
        "adapter",
        "rust_helper"
      ]
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "denied",
        "failed",
        "suspended"
      ]
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "previous_event_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(sha256:[a-f0-9]{64})?$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
