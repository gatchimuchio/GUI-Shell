{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gui-shell/schemas/agent_task.schema.json",
  "title": "AgentTask",
  "type": "object",
  "required": ["task_id", "session_id", "description", "status", "audit_event_id"],
  "additionalProperties": false,
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pending", "running", "blocked", "completed", "failed"]},
    "audit_event_id": {"type": "string", "minLength": 1}
  }
}
