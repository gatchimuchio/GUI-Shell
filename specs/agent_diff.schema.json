{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gui-shell/schemas/agent_diff.schema.json",
  "title": "AgentDiff",
  "type": "object",
  "required": ["diff_id", "session_id", "changed_files", "payload_hash", "audit_event_id", "rollback_candidate_id"],
  "additionalProperties": false,
  "properties": {
    "diff_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "payload_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "audit_event_id": {"type": "string", "minLength": 1},
    "rollback_candidate_id": {"type": "string", "minLength": 1}
  }
}
