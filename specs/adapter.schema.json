{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gui-shell/schemas/adapter.schema.json",
  "title": "Adapter",
  "type": "object",
  "required": [
    "adapter_id",
    "runtime_id",
    "contract_version",
    "authority_strip"
  ],
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "transport": {
      "type": "string",
      "enum": [
        "http",
        "stdio",
        "ipc",
        "mock"
      ]
    },
    "authority_strip": {
      "type": "boolean",
      "const": true
    },
    "content_exposure_policy_id": {
      "type": "string"
    },
    "declared_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Untrusted metadata. Must never grant authority.",
      "additionalProperties": true
    }
  }
}
